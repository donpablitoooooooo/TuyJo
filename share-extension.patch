+import MobileCoreServices
+import Social
+import UniformTypeIdentifiers
+import UIKit
+
+final class ShareViewController: SLComposeServiceViewController {
+  private let appGroupId = "group.com.privatemessaging.tuyjo"
+  private let manifestFileName = "shared_media.json"
+
+  override func isContentValid() -> Bool {
+    return true
+  }
+
+  override func viewDidAppear(_ animated: Bool) {
+    super.viewDidAppear(animated)
+    handleSharedItems()
+  }
+
+  override func didSelectPost() {
+    handleSharedItems()
+  }
+
+  override func configurationItems() -> [Any]! {
+    return []
+  }
+
+  private func handleSharedItems() {
+    guard let items = extensionContext?.inputItems as? [NSExtensionItem], !items.isEmpty else {
+      completeRequest()
+      return
+    }
+
+    let dispatchGroup = DispatchGroup()
+    var collectedUrls: [URL] = []
+    let urlsLock = NSLock()
+
+    for item in items {
+      guard let providers = item.attachments else { continue }
+      for provider in providers {
+        if provider.hasItemConformingToTypeIdentifier(UTType.image.identifier) {
+          dispatchGroup.enter()
+          loadItem(from: provider, typeIdentifier: UTType.image.identifier) { url in
+            if let url {
+              urlsLock.lock()
+              collectedUrls.append(url)
+              urlsLock.unlock()
+            }
+            dispatchGroup.leave()
+          }
+        } else if provider.hasItemConformingToTypeIdentifier(UTType.movie.identifier) {
+          dispatchGroup.enter()
+          loadItem(from: provider, typeIdentifier: UTType.movie.identifier) { url in
+            if let url {
+              urlsLock.lock()
+              collectedUrls.append(url)
+              urlsLock.unlock()
+            }
+            dispatchGroup.leave()
+          }
+        } else if provider.hasItemConformingToTypeIdentifier(UTType.pdf.identifier) {
+          dispatchGroup.enter()
+          loadItem(from: provider, typeIdentifier: UTType.pdf.identifier) { url in
+            if let url {
+              urlsLock.lock()
+              collectedUrls.append(url)
+              urlsLock.unlock()
+            }
+            dispatchGroup.leave()
+          }
+        }
+      }
+    }
+
+    dispatchGroup.notify(queue: .main) { [weak self] in
+      self?.persistAndOpenApp(with: collectedUrls)
+    }
+  }
+
+  private func loadItem(
+    from provider: NSItemProvider,
+    typeIdentifier: String,
+    completion: @escaping (URL?) -> Void
+  ) {
+    provider.loadFileRepresentation(forTypeIdentifier: typeIdentifier) { [weak self] url, _ in
+      if let url, let tempUrl = self?.copyToTemporaryLocation(url: url, typeIdentifier: typeIdentifier) {
+        completion(tempUrl)
+        return
+      }
+
+      provider.loadItem(forTypeIdentifier: typeIdentifier, options: nil) { item, _ in
+        if let url = item as? URL {
+          completion(url)
+        } else if let data = item as? Data,
+                  let tempUrl = self?.writeDataToTemporaryFile(data: data, typeIdentifier: typeIdentifier) {
+          completion(tempUrl)
+        } else {
+          completion(nil)
+        }
+      }
+    }
+  }
+
+  private func persistAndOpenApp(with urls: [URL]) {
+    guard let containerUrl = FileManager.default.containerURL(forSecurityApplicationGroupIdentifier: appGroupId) else {
+      completeRequest()
+      return
+    }
+
+    let sharedDir = containerUrl.appendingPathComponent("shared_media", isDirectory: true)
+    try? FileManager.default.createDirectory(at: sharedDir, withIntermediateDirectories: true)
+
+    var copiedPaths: [String] = []
+
+    for url in urls {
+      guard let destUrl = copyToSharedContainer(url: url, sharedDir: sharedDir) else { continue }
+      copiedPaths.append(destUrl.path)
+    }
+
+    guard !copiedPaths.isEmpty else {
+      completeRequest()
+      return
+    }
+
+    let manifestUrl = sharedDir.appendingPathComponent(manifestFileName)
+    if let data = try? JSONSerialization.data(withJSONObject: copiedPaths, options: []) {
+      try? data.write(to: manifestUrl)
+    }
+
+    openHostApp()
+  }
+
+  private func copyToSharedContainer(url: URL, sharedDir: URL) -> URL? {
+    let ext = url.pathExtension.isEmpty ? "dat" : url.pathExtension
+    let timestamp = Int(Date().timeIntervalSince1970 * 1000)
+    let destUrl = sharedDir.appendingPathComponent("shared_\(timestamp).\(ext)")
+
+    do {
+      let accessing = url.startAccessingSecurityScopedResource()
+      defer {
+        if accessing {
+          url.stopAccessingSecurityScopedResource()
+        }
+      }
+      if FileManager.default.fileExists(atPath: destUrl.path) {
+        try FileManager.default.removeItem(at: destUrl)
+      }
+      try FileManager.default.copyItem(at: url, to: destUrl)
+      return destUrl
+    } catch {
+      return nil
+    }
+  }
+
+  private func openHostApp() {
+    guard let url = URL(string: "ShareMedia://shared") else {
+      completeRequest()
+      return
+    }
+
+    extensionContext?.open(url, completionHandler: { [weak self] _ in
+      self?.completeRequest()
+    })
+  }
+
+  private func writeDataToTemporaryFile(data: Data, typeIdentifier: String) -> URL? {
+    let tempDir = FileManager.default.temporaryDirectory
+    let ext = UTType(typeIdentifier)?.preferredFilenameExtension ?? "dat"
+    let timestamp = Int(Date().timeIntervalSince1970 * 1000)
+    let tempUrl = tempDir.appendingPathComponent("shared_\(timestamp).\(ext)")
+
+    do {
+      try data.write(to: tempUrl)
+      return tempUrl
+    } catch {
+      return nil
+    }
+  }
+
+  private func copyToTemporaryLocation(url: URL, typeIdentifier: String) -> URL? {
+    let tempDir = FileManager.default.temporaryDirectory
+    let ext = url.pathExtension.isEmpty
+      ? (UTType(typeIdentifier)?.preferredFilenameExtension ?? "dat")
+      : url.pathExtension
+    let timestamp = Int(Date().timeIntervalSince1970 * 1000)
+    let tempUrl = tempDir.appendingPathComponent("shared_\(timestamp).\(ext)")
+
+    do {
+      let accessing = url.startAccessingSecurityScopedResource()
+      defer {
+        if accessing {
+          url.stopAccessingSecurityScopedResource()
+        }
+      }
+      if FileManager.default.fileExists(atPath: tempUrl.path) {
+        try FileManager.default.removeItem(at: tempUrl)
+      }
+      try FileManager.default.copyItem(at: url, to: tempUrl)
+      return tempUrl
+    } catch {
+      return nil
+    }
+  }
+
+  private func completeRequest() {
+    extensionContext?.completeRequest(returningItems: [], completionHandler: nil)
+  }
+}
