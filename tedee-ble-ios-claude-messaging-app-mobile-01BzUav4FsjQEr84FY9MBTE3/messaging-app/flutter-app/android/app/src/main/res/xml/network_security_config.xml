<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Permetti tutto il traffico in debug -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </base-config>

    <!-- Configurazione specifica per Cloud Run -->
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">europe-west1.run.app</domain>
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </domain-config>
</network-security-config>
