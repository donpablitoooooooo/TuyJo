rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ═══════════════════════════════════════════════════════════
    // FAMILIES COLLECTION
    // ═══════════════════════════════════════════════════════════
    match /families/{familyId} {

      // ❌ BLOCCA list() - Non puoi enumerare tutte le famiglie
      // Questo previene mass data scraping
      allow list: if false;

      // ✅ PERMETTI get() - Puoi leggere SE conosci il familyId
      // Ma indovinare familyId = impossibile (SHA256 = 2^256 possibilità)
      allow get: if true;

      // ✅ PERMETTI update/set - Per salvare dati come couple_selfie_url
      // Necessario per aggiornare il documento della famiglia
      allow update, create: if true;

      // ───────────────────────────────────────────────────────────
      // MESSAGES SUBCOLLECTION
      // ───────────────────────────────────────────────────────────
      match /messages/{messageId} {
        // ✅ Leggi/scrivi messaggi SE conosci familyId
        // Messaggi sono E2E encrypted (RSA-2048)
        allow read, write: if true;
      }

      // ───────────────────────────────────────────────────────────
      // USERS SUBCOLLECTION (FCM tokens)
      // ───────────────────────────────────────────────────────────
      match /users/{userId} {
        // ✅ Leggi/scrivi FCM tokens SE conosci familyId
        // userId = SHA256(publicKey)
        allow read, write: if true;
      }

      // ───────────────────────────────────────────────────────────
      // READ_RECEIPTS SUBCOLLECTION (Message read status)
      // ───────────────────────────────────────────────────────────
      match /read_receipts/{userId} {
        // ✅ Leggi/scrivi read receipts SE conosci familyId
        // userId = SHA256(publicKey)
        // Usato per tracciare quali messaggi sono stati letti
        allow read, write: if true;
      }

      // ───────────────────────────────────────────────────────────
      // LOCATIONS SUBCOLLECTION (Real-time location sharing)
      // ───────────────────────────────────────────────────────────
      match /locations/{userId} {
        // ✅ Leggi/scrivi posizioni GPS SE conosci familyId
        // userId = SHA256(publicKey)
        // Usato per condivisione posizione temporanea (1h/8h)
        allow read, write: if true;
      }

      // ───────────────────────────────────────────────────────────
      // CALLS SUBCOLLECTION (Voice call signaling + WebRTC)
      // ───────────────────────────────────────────────────────────
      match /calls/{callId} {
        // ✅ Leggi/scrivi segnali chiamata SE conosci familyId
        // Contiene: status, offer SDP, answer SDP
        allow read, write: if true;

        // ICE candidates per WebRTC (caller e callee)
        match /{subcollection}/{candidateId} {
          allow read, write: if true;
        }
      }
    }

    // ═══════════════════════════════════════════════════════════
    // PAIRING SIGNALS COLLECTION
    // ═══════════════════════════════════════════════════════════
    match /pairing_signals/{signalId} {
      // ❌ BLOCCA list() - Non puoi enumerare tutti i segnali
      allow list: if false;

      // ✅ PERMETTI get/read - Puoi leggere SE conosci il signalId
      // signalId = SHA256(publicKey) = impossibile da indovinare
      allow get: if true;

      // ✅ PERMETTI write/delete - Per creare e pulire segnali
      allow create, update, delete: if true;
    }
  }
}

// ═══════════════════════════════════════════════════════════════
// SECURITY MODEL:
// ═══════════════════════════════════════════════════════════════
//
// Layer 1: Compartmentalization
//   ❌ Non puoi elencare tutte le famiglie (list blocked)
//   ✅ Devi conoscere familyId specifico
//   🛡️ familyId = SHA256(pubKeys) = 2^256 = impossibile brute force
//
// Layer 2: Firebase Protection
//   🛡️ Rate limiting automatico
//   🛡️ Abuse detection
//   🛡️ IP blocking su comportamento sospetto
//
// Layer 3: End-to-End Encryption
//   🔐 Messaggi cifrati con RSA-2048
//   🔐 Senza chiavi private = dati inutili
//   🔐 Stesso standard di sicurezza di internet
//
// Risultato:
//   ✅ Mass data scraping: IMPOSSIBILE
//   ✅ Brute force familyId: IMPOSSIBILE (SHA256)
//   ✅ Attacco mirato: Possibile MA inutile (E2E encryption)
//   ✅ Architettura semplice (no auth, no backend)
// ═══════════════════════════════════════════════════════════════
